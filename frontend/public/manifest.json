{
  "manifest_version": 3,
  "name": "Hackathon Monitor",
  "short_name": "HackMonitor",
  "version": "1.0.0",
  "description": "Real-time integrity monitoring for hackathons — verify commits happen during the official time window and from the expected location.",

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "action": {
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Hackathon Monitor",
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "tabs"
  ],

  "host_permissions": [
    "http://localhost:5001/*",
    "http://localhost:3000/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "http://localhost:3000/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "options_page": "options.html",

  "web_accessible_resources": [
    {
      "resources": ["icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "commands": {
    "open-participant-dashboard": {
      "suggested_key": {
        "default": "Alt+H",
        "mac": "Alt+H"
      },
      "description": "Open Participant Dashboard"
    },
    "open-judge-dashboard": {
      "suggested_key": {
        "default": "Alt+J",
        "mac": "Alt+J"
      },
      "description": "Open Judge Dashboard"
    }
  },

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
